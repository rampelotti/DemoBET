# PostgreSQL connection string usada pelo Prisma
DATABASE_URL="postgresql://user:password@localhost:5432/demoscore?schema=public"

# Auth.js - gere um valor com `npx auth secret` ou `openssl rand -base64 32`
AUTH_SECRET="replace-with-a-random-secret"

# Credenciais do painel administrativo (somente ambiente de desenvolvimento)
ADMIN_EMAIL="admin@demoscore.com"
ADMIN_PASSWORD="admin123"

# The Odds API (https://the-odds-api.com) - usada só para validar a
# integração em /admin/odds-api-test (ver src/lib/providers/odds-api-provider.ts)
ODDS_API_KEY="sua-chave-da-the-odds-api"

# Fonte de odds/partidas: `mock` (padrão) ou `the-odds-api`
ODDS_PROVIDER="mock"
